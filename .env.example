APP_NAME=SHL Assessment Recommender
APP_ENV=development
LOG_LEVEL=INFO

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

SHL_CATALOG_BASE_URL=https://www.shl.com
SHL_CATALOG_START_URL=https://www.shl.com/solutions/products/product-catalog/
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_MAX_CONCURRENCY=5

DATA_DIR=data
CATALOG_JSON_PATH=data/shl_catalog.json
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDINGS_PATH=data/catalog_embeddings.npy
EMBEDDINGS_METADATA_PATH=data/catalog_embeddings_metadata.json
FAISS_INDEX_PATH=data/faiss.index
BM25_INDEX_PATH=data/bm25_index.pkl

RETRIEVAL_BM25_WEIGHT=0.45
RETRIEVAL_DENSE_WEIGHT=0.55
RETRIEVAL_CANDIDATE_LIMIT=30
RETRIEVAL_TOP_K=10
CROSS_ENCODER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
